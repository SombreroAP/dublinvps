# Polymarket auth.
#   signature_type=0 -> pure EOA (rare; funds on the EOA itself)
#   signature_type=1 -> Magic/email/Google login (Polymarket proxy wallet)
#   signature_type=2 -> Browser wallet connected through Polymarket (Safe proxy)
# For sig_type 1 or 2, POLY_FUNDER_ADDRESS = the proxy address shown in
# Polymarket UI (where USDC actually lives). The private key is the underlying
# signing key (exported from Polymarket settings for Magic accounts).
# NEVER commit the real key. On Dublin VPS: chmod 600 .env, owner = bot user.
POLY_PRIVATE_KEY=0x...
POLY_FUNDER_ADDRESS=0x...
POLY_SIGNATURE_TYPE=1
POLY_CHAIN_ID=137
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_GAMMA_HOST=https://gamma-api.polymarket.com

# Execution gate (fraction, not percent). 0.025 = 2.5%.
EDGE_THRESHOLD=0.025
# Hard ceiling per individual trade (caps Kelly when book is shallow).
MAX_POSITION_USDC=25.0
# Total capital allocated to the strategy. Kelly bets a fraction of THIS.
BANKROLL_USDC=100.0
# 0.5 = half-Kelly. Lower = safer. 1.0 = full-Kelly (much higher variance).
KELLY_FRACTION=0.5
ENTRY_WINDOW_START_SEC=45
ENTRY_WINDOW_END_SEC=5

# Mode: paper | live
MODE=paper

# Per-second log-price vol in bps for fair_p (Brownian) model.
# Calibrate with: /opt/sniper/.venv/bin/python scripts/calibrate_sigma.py
SIGMA_BPS_BTC=0.73
SIGMA_BPS_ETH=0.97
SIGMA_BPS_SOL=0.99

# Safety multiplier on σ. Accounts for fat tails / mean reversion the
# Brownian model misses. 1.0 = pure Gaussian realized vol. 1.5 = conservative.
SIGMA_SAFETY_MULT=1.5

# Cap on fair_p to prevent absurd confidence. 0.95 means: "never claim >95%
# probability of winning, no matter how big the move."
FAIR_P_CAP=0.95

# Trajectory / momentum filter.
# Lookback window (seconds) for computing recent price velocity.
TRAJECTORY_LOOKBACK_SEC=5
# Skip signals where momentum is strongly against the bet direction (bps/sec).
# E.g. if betting UP but price is falling >0.5 bps/sec, move is likely
# reversing. Set to 0 to disable the filter (still logs velocity).
MAX_COUNTER_TRAJECTORY_BPS_PER_SEC=0.5

# Correlation cap. Max picks per round across ALL assets. 1 = take the
# first qualifying signal in a round, skip subsequent asset picks for same
# round. 0 disables. Protects against 3-asset correlated losses.
MAX_PICKS_PER_ROUND=1

# Skip signals where our fair_p diverges from the market's implied p by more
# than this (in probability points). Guards against model overconfidence when
# the market has real information we don't.
MAX_DISAGREEMENT=0.30
# Skip if |Chainlink_current - Binance_mid| > this many bps. Chainlink
# can lag Binance by 10+ seconds in fast moves; this catches that case.
# 0 disables the check.
MAX_FEED_DIVERGENCE_BPS=5.0

# Minimum |z-score| of the Chainlink move vs remaining volatility.
# 2.0 = move must be 2+ standard deviations from zero (high-confidence moves only).
# Filters out fragile tiny-move signals that tend to reverse.
MIN_Z_SCORE=2.0

# Minimum model confidence to fire a signal (our fair_p).
# Evidence: picks with fair_p >= 0.85 win ~87%, below 0.85 win ~25%.
MIN_FAIR_P=0.85

# Which sides the bot is allowed to trade. "YES" / "NO" / "YES,NO".
# Currently YES-only: NO side was net -$95 in paper data; YES was +$90.
ENABLED_SIDES=YES

LOG_LEVEL=INFO

# Dashboard basic auth (user is always "admin"). Set to a long random string.
DASHBOARD_PASSWORD=change-me
